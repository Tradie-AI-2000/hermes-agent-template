model:
  default: "{{LLM_MODEL}}"
  provider: "auto"

terminal:
  backend: "{{TERMINAL_ENV}}"
  timeout: 60
  cwd: "/tmp"

agent:
  max_iterations: 50
  reasoning_effort: "medium"

platforms:
  api_server:
    enabled: true
    host: "0.0.0.0"
    port: {{PORT}}
    cors_origins:
      - "*"

data_dir: "{{HERMES_DIR}}"
